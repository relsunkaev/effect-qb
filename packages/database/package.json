{
  "name": "effect-db",
  "version": "0.13.0",
  "type": "module",
  "bin": {
    "effectdb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "imports": {
    "#postgres": "../querybuilder/src/postgres.ts",
    "#mysql": "../querybuilder/src/mysql.ts",
    "#internal/*": "../querybuilder/src/internal/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./src/cli.ts",
      "import": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.40",
    "@effect/sql-pg": "4.0.0-beta.40",
    "effect": "4.0.0-beta.40",
    "effect-qb": "workspace:*",
    "typescript": "^6.0.2"
  }
}
