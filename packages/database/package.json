{
  "name": "effect-db",
  "version": "0.20.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relsunkaev/effect-qb.git"
  },
  "bugs": {
    "url": "https://github.com/relsunkaev/effect-qb/issues"
  },
  "homepage": "https://github.com/relsunkaev/effect-qb#readme",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "effectdb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "imports": {
    "#postgres": "../querybuilder/src/postgres.ts",
    "#mysql": "../querybuilder/src/mysql.ts",
    "#sqlite": "../querybuilder/src/sqlite.ts",
    "#internal/*": "../querybuilder/src/internal/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postgres/pull": {
      "types": "./dist/postgres/pull.d.ts",
      "import": "./dist/postgres/pull.js"
    },
    "./postgres/push": {
      "types": "./dist/postgres/push.d.ts",
      "import": "./dist/postgres/push.js"
    },
    "./postgres/migrate": {
      "types": "./dist/postgres/migrate.d.ts",
      "import": "./dist/postgres/migrate.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/sql-pg": "4.0.0-beta.98",
    "effect-qb": "workspace:*",
    "tinyglobby": "0.2.17",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98"
  }
}
