{
  "name": "effect-db",
  "version": "0.13.0",
  "type": "module",
  "bin": {
    "effectdb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "imports": {
    "#postgres": "../querybuilder/src/postgres.ts",
    "#mysql": "../querybuilder/src/mysql.ts",
    "#internal/*": "../querybuilder/src/internal/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./postgres/pull": {
      "types": "./src/postgres/pull.ts",
      "import": "./dist/postgres/pull.js"
    },
    "./postgres/push": {
      "types": "./src/postgres/push.ts",
      "import": "./dist/postgres/push.js"
    },
    "./postgres/migrate": {
      "types": "./src/postgres/migrate.ts",
      "import": "./dist/postgres/migrate.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/sql": "^0.48.0",
    "@effect/sql-pg": "^0.48.0",
    "effect": "^3.19.3",
    "effect-qb": "workspace:*",
    "typescript": "^6.0.2"
  }
}
