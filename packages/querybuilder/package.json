{
  "name": "effect-qb",
  "version": "4.0.0-beta.98",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/relsunkaev/effect-qb.git"
  },
  "bugs": {
    "url": "https://github.com/relsunkaev/effect-qb/issues"
  },
  "homepage": "https://github.com/relsunkaev/effect-qb#readme",
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.5"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./src/postgres.ts",
      "import": "./dist/postgres.js"
    },
    "./postgres/metadata": {
      "types": "./src/postgres/metadata.ts",
      "import": "./dist/postgres/metadata.js"
    },
    "./mysql": {
      "types": "./src/mysql.ts",
      "import": "./dist/mysql.js"
    },
    "./sqlite": {
      "types": "./src/sqlite.ts",
      "import": "./dist/sqlite.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#standard": "./src/standard.ts",
    "#postgres": "./src/postgres.ts",
    "#mysql": "./src/mysql.ts",
    "#sqlite": "./src/sqlite.ts",
    "#internal/*": "./src/internal/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "beta"
  },
  "dependencies": {
    "pgsql-ast-parser": "^12.0.2"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98"
  }
}
