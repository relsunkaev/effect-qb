{
  "name": "effect-qb-workspace",
  "private": true,
  "version": "0.13.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "imports": {
    "#postgres": "./packages/querybuilder/src/postgres.ts",
    "#mysql": "./packages/querybuilder/src/mysql.ts",
    "#internal/*": "./packages/querybuilder/src/internal/*"
  },
  "scripts": {
    "build": "bun scripts/build-package.ts",
    "release": "bun scripts/release.ts",
    "test": "bun test",
    "test:types": "bunx tsgo -p tsconfig.type-tests.json",
    "test:integration": "bun scripts/test-integration.ts"
  },
  "devDependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/experimental": "^0.57.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/sql": "^0.48.0",
    "@effect/sql-mysql2": "0.48.0",
    "@effect/sql-pg": "0.48.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "latest",
    "effect": "^3.19.3",
    "effect-db": "workspace:*",
    "effect-qb": "workspace:*",
    "pgsql-ast-parser": "^12.0.2",
    "typescript": "^6.0.2"
  }
}
