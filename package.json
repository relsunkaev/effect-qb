{
  "name": "effect-qb-workspace",
  "private": true,
  "version": "0.13.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "imports": {
    "#postgres": "./packages/querybuilder/src/postgres.ts",
    "#mysql": "./packages/querybuilder/src/mysql.ts",
    "#internal/*": "./packages/querybuilder/src/internal/*"
  },
  "scripts": {
    "build": "bun scripts/build-package.ts",
    "release": "bun scripts/release.ts",
    "test": "bun test",
    "test:types": "tsgo -p tsconfig.type-tests.json",
    "test:integration": "bun scripts/test-integration.ts"
  },
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.40",
    "@effect/sql-mysql2": "4.0.0-beta.40",
    "@effect/sql-pg": "4.0.0-beta.40",
    "@types/bun": "latest",
    "@typescript/native-preview": "latest",
    "effect": "4.0.0-beta.40",
    "effect-db": "workspace:*",
    "effect-qb": "workspace:*",
    "pgsql-ast-parser": "^12.0.2",
    "typescript": "^6.0.2"
  }
}
