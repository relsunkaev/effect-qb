{
  "name": "effect-qb-workspace",
  "version": "0.19.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "imports": {
    "#standard": "./packages/querybuilder/src/standard.ts",
    "#postgres": "./packages/querybuilder/src/postgres.ts",
    "#mysql": "./packages/querybuilder/src/mysql.ts",
    "#sqlite": "./packages/querybuilder/src/sqlite.ts",
    "#internal/*": "./packages/querybuilder/src/internal/*"
  },
  "scripts": {
    "build": "bun scripts/build-package.ts",
    "generate:readme-types": "bun scripts/generate-readme-type-tests.ts",
    "release": "bun scripts/release.ts",
    "test:pack": "bun scripts/check-packed-querybuilder.ts",
    "test": "bun --config ./bunfig.test.toml test",
    "test:types": "bun run generate:readme-types && bunx tsgo -p tsconfig.type-tests.json",
    "test:integration": "bun scripts/test-integration.ts",
    "test:integration:datatypes": "bun scripts/test-datatype-matrix-integration.ts"
  },
  "devDependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/experimental": "^0.57.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/sql": "^0.48.0",
    "@effect/sql-mysql2": "0.48.0",
    "@effect/sql-pg": "0.48.0",
    "@effect/sql-sqlite-bun": "0.48.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260615.1",
    "effect": "^3.19.3",
    "effect-db": "workspace:*",
    "effect-qb": "workspace:*",
    "pgsql-ast-parser": "^12.0.2",
    "typescript": "^6.0.2"
  }
}
